<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D0D"
    tools:context=".MainActivity">

    <!-- 顶部工具栏 -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#1A1A2E"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:elevation="4dp">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_terminal"
            android:contentDescription="logo" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="DoBao TTS"
            android:textColor="#E0E0E0"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingStart="10dp" />

        <!-- 状态指示点 -->
        <View
            android:id="@+id/statusDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/status_dot"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="未运行"
            android:textColor="#888888"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- 按钮区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#111122"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp">

        <Button
            android:id="@+id/btnImport"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="导入 ZIP"
            android:textSize="13sp"
            android:backgroundTint="#2962FF"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnStart"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="▶ 启动"
            android:textSize="13sp"
            android:backgroundTint="#00C853"
            android:textColor="#FFFFFF"
            android:enabled="false" />

        <Button
            android:id="@+id/btnStop"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="■ 停止"
            android:textSize="13sp"
            android:backgroundTint="#D32F2F"
            android:textColor="#FFFFFF"
            android:enabled="false" />
    </LinearLayout>

    <!-- 信息栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0A0A1A"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp">

        <TextView
            android:id="@+id/tvPackageInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="未导入安装包"
            android:textColor="#666666"
            android:textSize="11sp" />

        <Button
            android:id="@+id/btnClearLog"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:text="清空"
            android:textSize="10sp"
            android:backgroundTint="#333333"
            android:textColor="#AAAAAA"
            android:paddingHorizontal="8dp" />
    </LinearLayout>

    <!-- 分隔线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#00FF4133" />

    <!-- 终端输出区域 -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="vertical">

        <TextView
            android:id="@+id/tvTerminal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:lineSpacingMultiplier="1.3"
            android:paddingHorizontal="12dp"
            android:paddingVertical="10dp"
            android:selectable="true"
            android:text=""
            android:textColor="#00FF41"
            android:textSize="12sp" />
    </ScrollView>

    <!-- 底部输入行（可扩展） -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="#111122"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$ "
            android:textColor="#00FF41"
            android:fontFamily="monospace"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvPortInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="等待启动..."
            android:textColor="#888888"
            android:fontFamily="monospace"
            android:textSize="11sp" />

        <Button
            android:id="@+id/btnOpenBrowser"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="打开页面"
            android:textSize="11sp"
            android:backgroundTint="#1565C0"
            android:textColor="#FFFFFF"
            android:paddingHorizontal="10dp"
            android:visibility="gone" />
    </LinearLayout>

</LinearLayout>
